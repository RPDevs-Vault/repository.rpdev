<?xml version='1.0' encoding='UTF-8'?>
<addon id="script.service.flaresolverr" name="FlareSolverr Service" provider-name="RPDev" version="1.1.0">
    <requires>
        <import addon="xbmc.python" version="3.0.0" />
    </requires>
    <extension point="xbmc.service" library="service.py" />
    <extension point="xbmc.addon.metadata">
        <platform>all</platform>
        <license>MIT</license>
        <summary lang="en_GB">Local FlareSolverr service for Kodi.</summary>
