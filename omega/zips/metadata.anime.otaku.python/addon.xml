<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="metadata.anime.otaku.python" name="Otaku Anime Scraper" version="1.2.1" provider-name="RPDevs">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.metadata.scraper.tvshows" library="scraper.py">
        <provides>tvshows episodes</provides>
    </extension>
    <extension point="xbmc.metadata.scraper.movies" library="scraper_movies.py">
        <provides>movies</provides>
    </extension>
    <extension point="kodi.context.item">
        <menu id="kodi.core.main">
            <item library="context_main.py">
                <label>Otaku: Standardize Anime Filenames (S01E01)</label>
                <visible>!IsEmpty(ListItem.FolderPath)</visible>
            </item>
        </menu>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>Anime Metadata Indexer powered by AniList and Otaku Mappings</summary>
        <description>A high-performance scraper mapping Eastern Anime databases to native Kodi formats.</description>
        <platform>all</platform>
    </extension>
</addon>
